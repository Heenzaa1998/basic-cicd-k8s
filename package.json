{
  "name": "basic-cicd-k8s",
  "version": "1.0.0",
  "private": true,
  "description": "DevOps setup with API service and background worker",
  "workspaces": [
    "services/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint \"services/*/src/**/*.ts\"",
    "test": "npm run test --workspaces --if-present",
    "dev:api": "npm run dev --workspace=services/api",
    "dev:worker": "npm run dev --workspace=services/worker"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "jest": "^30.3.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "typescript": "^5.4.0"
  }
}
